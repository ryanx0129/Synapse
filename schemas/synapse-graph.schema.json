{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synapse.local/schemas/synapse-graph.schema.json",
  "title": "Synapse Knowledge Graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "description",
    "domain",
    "createdAt",
    "clusters",
    "nodes",
    "links",
    "warnings"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "documentId": {
      "type": "string"
    },
    "clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "cluster",
          "summary",
          "difficulty",
          "importance",
          "initialMastery",
          "sourceSpans",
          "question",
          "rubric",
          "tags"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "shortLabel": {
            "type": "string"
          },
          "cluster": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "latex": {
            "type": "string"
          },
          "difficulty": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "importance": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "initialMastery": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "sourceSpans": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/sourceSpan"
            }
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "rubric": {
            "$ref": "#/$defs/rubric"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "source",
          "target",
          "type",
          "label",
          "explanation",
          "confidence",
          "prerequisiteWeight",
          "affectsMasteryPropagation",
          "sourceSpans"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "enum": [
              "prerequisite",
              "causes",
              "part_of",
              "contrasts_with",
              "applies_to",
              "derived_from",
              "example_of"
            ]
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "explanation": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "prerequisiteWeight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "affectsMasteryPropagation": {
            "type": "boolean"
          },
          "sourceSpans": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/sourceSpan"
            }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "sourceSpan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceId",
        "page",
        "quote"
      ],
      "properties": {
        "sourceId": {
          "type": "string",
          "minLength": 1
        },
        "page": {
          "type": "integer",
          "minimum": 1
        },
        "section": {
          "type": "string"
        },
        "quote": {
          "type": "string",
          "minLength": 1
        },
        "startOffset": {
          "type": "integer",
          "minimum": 0
        },
        "endOffset": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "rubric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiredConcepts",
        "optionalConcepts",
        "misconceptions",
        "acceptedKeywords",
        "referenceAnswer"
      ],
      "properties": {
        "requiredConcepts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "optionalConcepts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "misconceptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptedKeywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "referenceAnswer": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
